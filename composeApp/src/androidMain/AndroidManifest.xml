<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location (GPS capture for SOS payload) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Microphone (audio recording + voice command detection) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!--
        Telephony: CALL_PHONE and SEND_SMS are used exclusively for emergency SOS
        offline fallback — calling and texting the user's configured emergency contacts
        when no internet is available. This is core safety functionality, not default
        handler usage. No SMS/Call logs are read.
    -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.SEND_SMS"
        tools:ignore="SmsAndCallLogPolicy" />

    <!--
        Foreground service: keeps the SOS gesture/voice listener alive in background.
        Types declared on the <service> element below per Android 14+ requirements.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Notifications (push alerts to contacts) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Misc -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/guardian_logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/guardian_logo"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">
        <activity
            android:exported="true"
            android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            SOS foreground service: listens for gesture + voice triggers in background.
            Android 14+ (API 34) requires foregroundServiceType to be declared here.
            Using location + microphone types since the SOS engine needs both.
        -->
        <service
            android:name=".SOSForegroundService"
            android:exported="false"
            android:foregroundServiceType="location|microphone"
            tools:node="merge" />

        <service
            android:name=".ResqFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <receiver
            android:name=".MonitoringBootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>

    <!--
        Declare intent queries for telephony actions.
        Required on Android 11+ for CALL_PHONE and SEND_SMS intents.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.CALL" />
            <data android:scheme="tel" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>
    </queries>

</manifest>